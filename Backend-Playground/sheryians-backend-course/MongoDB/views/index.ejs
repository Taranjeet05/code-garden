<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="bg-zinc-800 h-screen w-full">
      <h1 class="text-center p-10 text-blue-600 text-5xl font-mono">
        Create a User 📝
      </h1>
      <nav class="ml-25 mb-15">
        <a href="/read" class="text-blue-500 hover:text-blue-200">Read Users</a>
      </nav>

      <div class="form">
        <form
          action=""
          class="flex flex-col items-center justify-center p-10 gap-10 text-white"
        >
          <input
            type="text"
            name="name"
            id="name"
            placeholder="Name"
            class="border-1 border-zinc-700 bg-transparent px-10 py-4 text-xl font-mono outline-none rounded-lg"
          />
          <input
            type="email"
            name="email"
            id="email"
            placeholder="Email"
            class="border-1 border-zinc-700 bg-transparent px-10 py-4 text-xl font-mono outline-none rounded-lg"
          />
          <input
            type="text"
            name="image"
            id="image"
            placeholder="Image URL"
            class="border-1 border-zinc-700 bg-transparent px-10 py-4 text-xl font-mono outline-none rounded-lg"
          />
          <input
            type="button"
            value="Create a User"
            class="bg-blue-700 hover:bg-blue-900 cursor-pointer w-xs rounded-lg font-mono text-lg py-2"
          />
        </form>
      </div>
    </div>
  </body>
</html>
